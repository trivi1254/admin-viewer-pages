# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# El archivo ".env" NUNCA debe subirse a GitHub (ya está en .gitignore
# gracias a la regla "*.local"; si no, agrégalo tú mismo).
# ============================================================

# ---- Firebase (login actual, se queda igual por ahora) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- Supabase ----
# Estas dos SÍ son seguras de usar en el frontend (son públicas por diseño).
# Las sacas en: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Stripe (clave pública, segura para el frontend) ----
# Dashboard de Stripe -> Developers -> API keys -> Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=

# ============================================================
# Lo de abajo NO va en este archivo ni en el frontend.
# Se configura como "Secrets" dentro de Supabase (Edge Functions),
# nunca en un .env que se empaqueta con el sitio:
#
#   STRIPE_SECRET_KEY            (Stripe -> Developers -> API keys)
#   STRIPE_WEBHOOK_SECRET         (Stripe -> Developers -> Webhooks)
#   SUPABASE_SERVICE_ROLE_KEY     (Supabase -> Project Settings -> API)
#   SUPABASE_URL                  (se inyecta sola en las Edge Functions)
#
# Se configuran así, desde la terminal, una sola vez:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_xxx
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
# ============================================================
